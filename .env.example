# ============================================================
# JobBot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Gmail ---
# Option A: App Password (recommended for personal use)
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B: OAuth (future)
# GMAIL_OAUTH_CREDENTIALS_PATH=config/credentials.json

# --- App ---
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Scraper ---
SCRAPER_HEADLESS=true          # false = see the browser window
SCRAPER_DELAY_MIN=2            # seconds min between actions
SCRAPER_DELAY_MAX=5            # seconds max between actions

# --- Database ---
DATABASE_URL=sqlite:///data/jobbot.db

# --- Paths ---
CV_PATH=data/cvs/my_cv.pdf
CERTIFICATES_DIR=data/certificates/
